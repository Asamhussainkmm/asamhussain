rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Singleton page content (hero/about/skills/experience/contact), projects,
    // and testimonials: public read so the site renders, write only from the
    // signed-in admin (the admin panel authenticates with Firebase Auth).
    match /portfolio/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact form submissions: anyone can create one, but only the admin
    // can read the inbox or mark messages as read/delete them.
    match /messages/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Lightweight page-view logging: anyone (the site itself) can log a
    // view, only the admin can read the analytics.
    match /pageviews/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
